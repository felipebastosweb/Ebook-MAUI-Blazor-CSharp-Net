@page "/Reuniao/Cadastrar"

@rendermode InteractiveServer

@using CondominioServer.Data.Models;

<EditForm Model="NovaReuniao" Enhance>
    <h3 class="display-4">Cadastrar Reunião</h3>
    
    <div class="mb-3">
        <label class="form-label">Condomínio</label>
        <p>@NovaReuniao.Condominio.Nome</p>
        <p>Síndico: @NovaReuniao.Condominio.SindicoAtivo?.Nome</p>
    </div>

    <div class="mb-3">
        <label class="form-label">Tipo de Reunião</label>
        <InputSelect @bind-Value="NovaReuniao.ReuniaoTipo" class="form-control">
            @foreach(var type in ReuniaoTypes)
            {
                <option value="@type.Id">@type.Nome</option>
            }
        </InputSelect>
    </div>
    <div class="mb-3">
        <label class="form-label">Assunto da Reunião</label>
        <InputText @bind-Value="NovaReuniao.Titulo" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Pauta da Reunião</label>
        <InputText @bind-Value="NovaReuniao.Pauta" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Conteúdo da Reunião</label>
        <InputText @bind-Value="NovaReuniao.Ata" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Data e Horário</label>
        <InputDate @bind-Value="NovaReuniao.DataInicio" class="form-control" Type="InputDateType.DateTimeLocal" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
    </div>
</EditForm>

@code
{
    public Condominio Condominio { get; set; } = new();
    public List<ReuniaoTipo> ReuniaoTypes { get; set; } = new();
    public Reuniao NovaReuniao { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        NovaReuniao.Condominio = Condominio;
    }
}