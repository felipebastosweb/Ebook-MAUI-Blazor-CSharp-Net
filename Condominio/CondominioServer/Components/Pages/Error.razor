@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>


<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="alert alert-danger text-center shadow-sm">
                <h1 class="display-5 mb-3"><i class="bi bi-exclamation-triangle-fill me-2"></i>Erro</h1>
                <h4>Ocorreu um erro ao processar sua solicitação.</h4>
                @if (ShowRequestId)
                {
                    <p class="mt-3">
                        <strong>ID da Requisição:</strong> <code>@RequestId</code>
                    </p>
                }
            </div>
            <div class="card mt-4">
                <div class="card-body">
                    <h5 class="card-title">Ambiente de Desenvolvimento</h5>
                    <p class="card-text mb-1">
                        Ative o ambiente <strong>Development</strong> para exibir informações detalhadas sobre o erro.
                    </p>
                    <p class="card-text">
                        <strong>Não ative o ambiente Development em produção.</strong> Isso pode expor informações sensíveis a usuários finais.
                        Para depuração local, defina a variável <strong>ASPNETCORE_ENVIRONMENT</strong> como <strong>Development</strong> e reinicie o app.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
