@inherits LayoutComponentBase


<NavMenu />

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    @Body
                </div>
            </div>
        </div>
    </div>
</div>

<footer class="footer mt-auto py-3 bg-light border-top">
    <div class="container text-center">
        <span class="text-muted">&copy; @DateTime.Now.Year Condominio SaaS Platform</span>
    </div>
</footer>

<div id="blazor-error-ui" data-nosnippet class="alert alert-danger fixed-bottom m-0 rounded-0 text-center" style="display:none;">
    Ocorreu um erro inesperado.
    <a href="." class="alert-link reload">Recarregar</a>
    <span class="dismiss ms-2" style="cursor:pointer;">&times;</span>
</div>
